# App
NEXT_PUBLIC_APP_NAME=GreenStake
SESSION_DAYS=7

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key_here

# Payment gateway selection
# auto -> prefers Razorpay when keys exist; otherwise mock fallback
PAYMENT_PROVIDER=auto
PAYMENT_FALLBACK_PROVIDER=mock

# Razorpay (primary)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

